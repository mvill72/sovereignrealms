# WalletConnect Project ID
# Get yours at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional: Web3.storage API key for real IPFS pinning
# Get yours at: https://web3.storage
NEXT_PUBLIC_WEB3_STORAGE_TOKEN=your_token_here

# Smart Contract Addresses (after deployment)
# Get these from running: bun run contracts:deploy:sepolia
NEXT_PUBLIC_PROFILE_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CIRCLE_KEYS_CONTRACT=0x0000000000000000000000000000000000000000

# ZK-Proof CircleKeys (v0.2+)
# Get ZK verifier from: npx hardhat run scripts/deployZKCircleVerifier.ts --network sepolia
NEXT_PUBLIC_ZK_VERIFIER_CONTRACT=0x0000000000000000000000000000000000000000
# Semaphore v4 addresses per network (from https://docs.semaphore.pse.dev/deployed-contracts)
NEXT_PUBLIC_SEMAPHORE_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: Chain ID (defaults to localhost if not set)
# 1 = Mainnet, 11155111 = Sepolia, 31337 = Hardhat local
NEXT_PUBLIC_CHAIN_ID=11155111

# Smart Contract Deployment (DO NOT COMMIT PRIVATE KEY!)
# Only needed for contract deployment, not frontend
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PRIVATE_KEY=your_private_key_for_deployment_NEVER_COMMIT_THIS

# Semaphore v4 Deployment Addresses (for ZK CircleKeys deployment)
# See: https://docs.semaphore.pse.dev/deployed-contracts
SEMAPHORE_V4_MAINNET=0x0000000000000000000000000000000000000000
SEMAPHORE_V4_SEPOLIA=0x0000000000000000000000000000000000000000
SEMAPHORE_V4_POLYGON=0x0000000000000000000000000000000000000000
SEMAPHORE_V4_OPTIMISM=0x0000000000000000000000000000000000000000
SEMAPHORE_V4_ARBITRUM=0x0000000000000000000000000000000000000000
SEMAPHORE_V4_BASE=0x0000000000000000000000000000000000000000
# Generic fallback (if not set per-network)
SEMAPHORE_V4_ADDRESS=0x0000000000000000000000000000000000000000

# ActivityPub Federation (Optional)
# Your realm's domain for Fediverse federation
NEXT_PUBLIC_REALM_DOMAIN=localhost:3000
NEXT_PUBLIC_REALM_PROTOCOL=http://
# In production, use your actual domain:
# NEXT_PUBLIC_REALM_DOMAIN=your-realm.eth
# NEXT_PUBLIC_REALM_PROTOCOL=https://
